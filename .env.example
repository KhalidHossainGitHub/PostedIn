# Copy to .env.local and paste your key from https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Rate limiting for POST /api/generate (Upstash Redis — free tier works)
# https://console.upstash.com → create a Redis database → REST API → copy URL + token
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Optional: max requests per IP per sliding 1-minute window (default 20)
# RATE_LIMIT_MAX_REQUESTS=20
